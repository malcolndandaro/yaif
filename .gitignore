# Databricks Asset Bundle state
.databricks/
.bundle/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# Generated domain YAML preview dir (scripts/generate_api_domains.py default out-dir)
build/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Engagement-specific artifacts — not part of the reusable framework
reports/

# Secrets / customer-provided artifacts — NEVER commit (may contain plaintext creds)
# e.g. exported API client collections often embed usernames/passwords/tokens
*.postman_collection.json
*.postman_environment.json
secrets/
*.secrets.*
*credentials*.json
